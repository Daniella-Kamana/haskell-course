   "source": [
    "take' :: Int -> [a] -> [a]\n",
    "take' n _      | n <= 0 = []\n",
    "take' _ []              = []\n",
    "take' n (x:xs)          = x : take' (n-1) xs\n",
    "\n",
    "take' 3 [1,2,3,4,5]\n",
    "take' (-3) [1,2,3,4,5]"
